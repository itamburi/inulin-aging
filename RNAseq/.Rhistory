enriched = enrichr(dn,databases = mydb)
df1 = as.data.frame(enriched)
colnames(df1) = sub(".*?\\.", "", colnames(df1))
df1 = subset(df1, P.value <= 0.05)
View(df1)
enr2= plotEnrich(enriched[[1]], showTerms = 20, numChar = 100, y = "Count", orderBy = "P.value", title="Downregulated Pathways in ID")
library(cowplot)
